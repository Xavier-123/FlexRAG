# --- LLM 相关 ---
LLM_MODEL=Qwen/Qwen3.5-35B-A3B
LLM_BASE_URL=https://api-inference.modelscope.cn/v1
LLM_API_KEY=ms-
CONTEXT_MAX_TOKENS=4096

# --- Embedding 相关 ---
EMBEDDING_MODEL=Qwen3-Embedding-0.6B
EMBEDDING_BASE_URL=http://127.0.0.1:19002/v1/embeddings
EMBEDDING_API_KEY=sk-1234567890

# --- 知识库相关 ---
KNOWLEDGE_PERSIST_DIR=../data/knowledge_persist_dir/hotpotqa/
KNOWLEDGE_CHUNK_SIZE=512
KNOWLEDGE_CHUNK_OVERLAP=50

# --- 向量检索相关 ---
TOP_K_RETRIEVAL=5
VECTOR_STORE_TYPE=faiss

# --- Reranker 相关 ---
RERANKER_BASE_URL=http://127.0.0.1:19003/v1/rerank
RERANKER_MODEL=Qwen3-Reranker-0.6B
RERANKER_API_KEY=sk-1234567890
TOP_K_RERANK=5

# --- 执行控制与文件 IO ---
# DEBUG，INFO，WARNING，ERROR，CRITICAL
LOG_LEVEL=INFO
MAX_ITERATIONS=1
MAX_CONCURRENT_TASKS=1
INPUT_FILE="E:\LLM\6-RAG\FlexRAG\data\hotpotqa-100.json"
OUTPUT_FILE="./eval_results/hotpotqa-RAG-results.json"
